# ========================================
# Hotel Management System - Configuration Template
# ========================================
# Copy this file to: application-secret.properties
# Then fill in your actual values
# DO NOT commit application-secret.properties to Git!
# ========================================

# ===== DATABASE CONFIGURATION =====
# SQL Server connection string
# Replace <your_database_name> with your actual database name (e.g., daotien_hotel)
datasource.url=jdbc:sqlserver://localhost:1433;databaseName=<your_database_name>;encrypt=true;trustServerCertificate=true;

# SQL Server username (default: sa for local SQL Server Express)
datasource.username=sa

# SQL Server password
datasource.password=<your_sql_password>


# ===== APPLICATION SETTINGS =====
# Default admin password for first login
daotien.password=admin123

# Hotel name displayed in the application
daotien.name=Dao Tien Hotel


# ===== EMAIL CONFIGURATION (Gmail) =====
# Gmail account for sending emails (invoices, password reset)
daotien.mail.email=your-email@gmail.com

# Gmail App Password (NOT your Gmail password!)
# How to get App Password:
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Copy 16-character password (remove spaces if any)
daotien.mail.password=xxxx xxxx xxxx xxxx

# SMTP Configuration (Gmail) - DO NOT CHANGE
mail.smtp.auth=true
mail.smtp.starttls.enable=true
mail.smtp.host=smtp.gmail.com
mail.smtp.port=587
mail.smtp.charset=UTF-8


# ===== MOMO PAYMENT GATEWAY (OPTIONAL) =====
# MoMo API credentials for payment integration
# Contact MoMo Business to get these credentials: https://business.momo.vn/
# For testing, you can leave these as placeholder values (payment won't work)

momo.partner.code=YOUR_PARTNER_CODE
momo.access.key=YOUR_ACCESS_KEY
momo.secret.key=YOUR_SECRET_KEY
momo.endpoint.create=https://payment.momo.vn/v2/gateway/api/create
momo.endpoint.query=https://payment.momo.vn/v2/gateway/api/query


# ========================================
# EXAMPLE CONFIGURATION (for reference)
# ========================================
# datasource.url=jdbc:sqlserver://localhost:1433;databaseName=daotien_hotel;encrypt=true;trustServerCertificate=true;
